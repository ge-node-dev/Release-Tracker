#!/bin/bash
set -e 

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo -e "\n${BLUE}🔹 Running Prettier...${NC}\n"
npm run format || { echo -e "${RED}❌ Formatting failed${NC}"; exit 1; }

echo -e "\n${BLUE}🔹 Checking TypeScript...${NC}\n"
npx tsc --noEmit || { echo -e "${RED}❌ TypeScript check failed${NC}"; exit 1; }

echo -e "\n${YELLOW}🔹 Running ESLint...${NC}\n"
npm run lint || { echo -e "${RED}❌ Linting failed${NC}"; exit 1; }

echo -e "\n${YELLOW}🔹 Running Stylelint...${NC}\n"
npm run lint:styles || { echo -e "${RED}❌ Stylelint failed${NC}"; exit 1; }

echo -e "\n${BLUE}🔹 Running database tests...${NC}\n"
npm run test:queries || { echo -e "${RED}❌ Database test failed${NC}"; exit 1; }

echo -e "\n${BLUE}🔹 Running authorization tests...${NC}\n"
npm run test:auth || { echo -e "${RED}❌ Authorization test failed${NC}"; exit 1; }

echo -e "\n${GREEN}✅ Pre-commit completed successfully!${NC}\n"
