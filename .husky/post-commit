#!/bin/bash

# Skip if this commit is from the docs-update hook itself (prevent infinite loop)
COMMIT_MSG=$(git log -1 --pretty=%s)
if [[ "$COMMIT_MSG" == docs:* ]]; then
   exit 0
fi

echo -e "\n\033[0;34m🔹 Checking if AGENTS.md needs updating...\033[0m\n"

claude -p "Run git diff HEAD~1 --name-only to see which files changed in the last commit.
Read the current AGENTS.md file.
Check if any changes affect the project structure, architecture, routes, modules, shared UI components, environment variables, key dependencies, or other sections documented in AGENTS.md.
If AGENTS.md needs updates — edit it to reflect the changes. Keep the existing format and style.
If AGENTS.md is already accurate — do nothing, just say 'No updates needed'.
If you made changes to AGENTS.md — run git add AGENTS.md and then git commit -m 'docs: update AGENTS.md'.

IMPORTANT:
- Only update sections that are actually affected by the changes.
- Do NOT rewrite the entire file — make minimal, targeted edits.
- Do NOT add new sections unless the changes clearly require it.
- Do NOT update the file if the changes are purely cosmetic (styling, formatting, minor bug fixes).
- The docs commit must ONLY include AGENTS.md — never stage other files." --model claude-opus-4-6 2>&1

echo -e "\n\033[0;32m✅ Post-commit hook completed\033[0m\n"
